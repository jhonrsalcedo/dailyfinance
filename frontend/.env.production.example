# Frontend Environment Variables (Production)
# Copia este archivo a .env.local y completa los valores

# NextAuth - Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your-nextauth-secret-here-min-32-chars

# URL de producción (sin trailing slash)
NEXTAUTH_URL=https://your-vercel-app.vercel.app

# URL del backend en producción
NEXT_PUBLIC_API_URL=https://your-render-app.onrender.com/api/v1