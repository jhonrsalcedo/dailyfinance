# ============================================
# Daily Finance App - Environment Configuration
# ============================================
# Este archivo NO debe ser commiteado al repo
# Copia .env.example y renombra a .env

# ============================================
# Desarrollo Local (default)
# ============================================
# DATABASE_URL=<tu-turso-db>  # libsql://dailyfinance-jhonrsalcedo.aws-us-east-2.turso.io
# TURSO_AUTH_TOKEN=<tu-token>
# ENVIRONMENT=development
# JWT_SECRET=dev-secret-key
# NEXTAUTH_SECRET=dev-secret-key
# NEXTAUTH_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ============================================
# Producción (Render + Vercel)
# ============================================
# DATABASE_URL=postgres://...turso.io  # Usar PostgreSQL de Turso
# ENVIRONMENT=production
# JWT_SECRET=<generado>
# NEXTAUTH_SECRET=<generado>
# NEXTAUTH_URL=https://tu-vercel.app
# NEXT_PUBLIC_API_URL=https://tu-render.onrender.com/api/v1