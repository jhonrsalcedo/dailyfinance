# Daily Finance App - Variables de Entorno

# Backend (desarrollo local - SQLite)
# DATABASE_URL=sqlite:///db/dailyfinance.db

# Backend (producción - PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/dailyfinance

# API Keys (si se necesitan en el futuro)
# OPENAI_API_KEY=your_api_key_here
# STRIPE_API_KEY=your_stripe_key_here

# Frontend
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
