# Daily Finance App - Variables de Entorno
# ============================================
# COPIA ESTE ARCHIVO A .env Y COMPLETA LOS VALORES
# cp .env.example .env
# ============================================

# --- ENVIRONMENT ---
ENVIRONMENT=development  # development | production

# --- DATABASE ---
# Cambia según el entorno
#
# --- LOCAL / DESARROLLO (SQLite) ---
DATABASE_URL=sqlite:///db/dailyfinance.db

# --- PRODUCCIÓN (Opciones gratuitas) ---
#
# NEON (PostgreSQL Serverless) - RECOMENDADO
# https://neon.tech
# 500MB gratuito, auto-suspend
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname
#
# TURSO (libSQL - fork de SQLite)
# https://turso.tech
# 9GB gratuito, muy bajo latency
# DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-token-here
#
# RAILWAY (PostgreSQL)
# https://railway.app
# 1GB gratuito, fácil deploy
# DATABASE_URL=postgresql://user:password@host:5432/dbname
#
# SUPABASE (PostgreSQL + extras)
# https://supabase.com
# 500MB gratuito, auth incluido
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres
#
# PLANETSCALE (MySQL)
# https://planetscale.com
# 1GB gratuito, branching como git
# DATABASE_URL=mysql://user:password@aws.connect.psdb.cloud/dbname

# --- JWT SECRET ---
# CAMBIA ESTO EN PRODUCCIÓN!!!
JWT_SECRET=dailyfinance-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30

# --- FRONTEND ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# NEXT_PUBLIC_API_URL=https://tu-backend.onrender.com/api/v1